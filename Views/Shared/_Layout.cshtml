<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Przychodnia</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
            :root {
                --dark-navy: #1B263B; /* Trzeci kolor - mocny granat */
                --light-blue: #B2DAFA; /* Jasny niebieski */
                --soft-gray: #F0F2F5; /* Jasny szary */
            }

            body {
                /* Gradient idący w biały kolor w tle */
                background: linear-gradient(180deg, var(--soft-gray) 0%, #FFFFFF 100%);
                background-attachment: fixed;
                min-height: 100vh;
                margin: 0;
                font-family: 'Segoe UI', Arial, sans-serif;
            }

            /* Nagłówek - 3 bloki mocno oddzielone */
            .header-container {
                display: flex;
                gap: 15px;
                padding: 15px;
            }

            .header-block {
                background-color: var(--light-blue);
                border: 5px solid var(--dark-navy); /* Mocne pogrubienie */
                padding: 20px;
                flex: 1;
                text-align: center;
                font-weight: 900;
                font-size: 1.5rem;
                color: var(--dark-navy);
            }

            /* Nawigacja - mocno pogrubiona */
            nav.main-nav {
                background-color: white;
                border: 5px solid var(--dark-navy);
                margin: 0 15px 20px 15px;
                padding: 10px;
                display: flex;
                flex-wrap: wrap;
                gap: 10px;
            }

            .nav-btn {
                border: 3px solid var(--dark-navy);
                padding: 8px 15px;
                text-decoration: none;
                color: var(--dark-navy);
                font-weight: bold;
                text-transform: uppercase;
                transition: 0.2s;
            }

                .nav-btn:hover {
                    background-color: var(--dark-navy);
                    color: white;
                }

            /* Główna sekcja - bez pogrubień */
            .main-content {
                padding: 0 20px 20px 20px;
            }
    </style>
</head>
<body>

    <header class="header-container">
        <div class="header-block">PRZYCHODNIA</div>
        <div class="header-block">SYSTEM MEDYCZNY</div>
        <div class="header-block">V1.0</div>
    </header>

    <nav class="main-nav">
        <a asp-controller="Home" asp-action="Index" class="nav-btn">Strona Główna</a>
        <a href="#" class="nav-btn">Przycisk 2</a>
        <a href="#" class="nav-btn">Przycisk 3</a>
        <a href="#" class="nav-btn">Przycisk 4</a>
        <a href="#" class="nav-btn">Przycisk 5</a>
    </nav>

    <main class="main-content">
        @RenderBody()
    </main>
    <link rel="stylesheet" href="css/site.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

</body>
</html>