@model przychodnia.Models.Uzytkownik

@{
    ViewData["Title"] = "Edycja danych pacjenta";
}

<div class="container mt-4">
    <div class="card shadow-sm" style="max-width: 600px; margin: auto; border-radius: 10px;">
        
        <div class="card-header text-white" style="background-color: #1B263B;">
            <h4 class="mb-0"><i class="fas fa-user-edit"></i> Edycja pacjenta: @Model.Imie @Model.Nazwisko</h4>
        </div>
        
        <div class="card-body p-4">
            <div asp-validation-summary="All" class="text-danger small mb-3"></div>

            <form asp-action="EdytujPacjenta" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ID" />
                <input type="hidden" asp-for="Login" />
                <input type="hidden" asp-for="Haslo" />
                <input type="hidden" asp-for="Permisje" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label font-weight-bold">Imię</label>
                        <input asp-for="Imie" class="form-control" />
                        <span asp-validation-for="Imie" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label font-weight-bold">Nazwisko</label>
                        <input asp-for="Nazwisko" class="form-control" />
                        <span asp-validation-for="Nazwisko" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Numer PESEL</label>
                    <input asp-for="Pesel" class="form-control" maxlength="11" />
                    <span asp-validation-for="Pesel" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Adres zamieszkania</label>
                    <input asp-for="Adres" class="form-control" />
                    <span asp-validation-for="Adres" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label font-weight-bold">Adres E-mail</label>
                        <input asp-for="Email" class="form-control" type="email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label font-weight-bold">Telefon</label>
                        <input asp-for="Telefon" class="form-control" />
                        <span asp-validation-for="Telefon" class="text-danger small"></span>
                    </div>
                </div>

                <hr />

                <div class="d-flex justify-content-between align-items-center mt-4">
                    <a href="@Url.Action("PracownikPodglad", new { id = Model.ID })" class="btn btn-outline-secondary">
                        <i class="fas fa-times"></i> Anuluj
                    </a>
                    <button type="submit" class="btn btn-primary px-4" style="background-color: #1B263B; border: none;">
                        <i class="fas fa-save"></i> Zapisz zmiany
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}