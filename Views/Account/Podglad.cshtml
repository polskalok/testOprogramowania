@model przychodnia.Models.Uzytkownik

@{
    ViewData["Title"] = "Podgląd Użytkownika";
}

<style>
    .user-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        max-width: 800px;
        margin: 20px auto;
        overflow: hidden;
        border: 1px solid #dee2e6;
    }

    .card-header-custom {
        background-color: #B2DAFA;
        padding: 20px;
        border-bottom: 4px solid #1B263B;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .card-body-custom {
        padding: 30px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .info-group {
        border-bottom: 1px dashed #B2DAFA;
        padding-bottom: 10px;
    }

    .info-label {
        font-weight: bold;
        color: #1B263B;
        font-size: 0.85rem;
        text-transform: uppercase;
    }

    .info-value {
        font-size: 1.1rem;
        color: #333;
    }

    .status-active { color: #28a745; font-weight: bold; }
    .status-inactive { color: #dc3545; font-weight: bold; }
</style>

<div class="user-card">
    <div class="card-header-custom">
        <h3 class="m-0">Karta Użytkownika: @Model.Imie @Model.Nazwisko</h3>
        <span class="@(Model.CzyAktywny ? "status-active" : "status-inactive")">
            @(Model.CzyAktywny ? "● AKTYWNY" : "● ZAPOMNIANY")
        </span>
    </div>

    <div class="card-body-custom">
        <div class="info-group">
            <div class="info-label">Login systemowy</div>
            <div class="info-value">@Model.Login</div>
        </div>
        <div class="info-group">
            <div class="info-label">PESEL</div>
            <div class="info-value">@Model.Pesel</div>
        </div>
        <div class="info-group">
            <div class="info-label">Data urodzenia</div>
            <div class="info-value">@Model.DataUrodzenia.ToString("dd.MM.yyyy")</div>
        </div>
        <div class="info-group">
            <div class="info-label">Płeć</div>
            <div class="info-value">@Model.Plec</div>
        </div>
        <div class="info-group">
            <div class="info-label">Adres zamieszkania</div>
            <div class="info-value">@Model.Adres</div>
        </div>
        <div class="info-group">
            <div class="info-label">Email</div>
            <div class="info-value">@Model.Email</div>
        </div>
        <div class="info-group">
            <div class="info-label">Telefon</div>
            <div class="info-value">@Model.Telefon</div>
        </div>
        <div class="info-group">
            <div class="info-label">Uprawnienia</div>
            <div class="info-value">
                @(Model.Permisje == 1 ? "Administrator" : Model.Permisje == 2 ? "Pracownik" : "Użytkownik")
            </div>
        </div>
    </div>
    
    <div class="p-3 bg-light text-end">
        <a href="@Url.Action("AdminPanel")" class="btn-action">Powrót do listy</a>
    </div>
</div>