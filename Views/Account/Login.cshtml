@{
    ViewData["Title"] = "Logowanie";
}

<style>
    .login-container {
        max-width: 450px;
        margin: auto;
        text-align: center;
    }

    .login-form {
        background: white;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        border-top: 4px solid #1B263B;
    }

    .login-form h3 {
        color: #1B263B;
        margin-bottom: 25px;
        font-weight: bold;
    }

    .form-group {
        margin-bottom: 15px;
    }

    .form-group input {
        border: 2px solid #B2DAFA;
        border-radius: 5px;
        padding: 12px;
        width: 100%;
    }

    .form-group input:focus {
        outline: none;
        border-color: #1B263B;
        background-color: #f9f9f9;
    }

    .btn-group {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-top: 20px;
    }

    .btn-login {
        background-color: #1B263B;
        color: white;
        padding: 12px;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        font-weight: bold;
        transition: all 0.3s;
    }

    .btn-login:hover {
        background-color: #0f1824;
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
    }

    .btn-register {
        background-color: #B2DAFA;
        color: #1B263B;
        padding: 12px;
        border: 2px solid #1B263B;
        border-radius: 5px;
        cursor: pointer;
        font-weight: bold;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s;
    }

    .btn-register:hover {
        background-color: #a8d5f7;
        text-decoration: none;
    }

    .btn-recovery {
        display: block;
        margin-top: 20px;
        color: #1B263B;
        text-decoration: none;
        font-weight: 600;
        padding: 10px;
        border-bottom: 2px solid transparent;
        transition: all 0.3s;
    }

    .btn-recovery:hover {
        color: #B2DAFA;
        border-bottom: 2px solid #1B263B;
    }

    .alert {
        margin-bottom: 20px;
        padding: 15px;
        border-radius: 5px;
        border-left: 4px solid;
    }

    .alert-danger {
        background-color: #f8d7da;
        border-color: #dc3545;
        color: #721c24;
    }

    .alert-success {
        background-color: #d4edda;
        border-color: #28a745;
        color: #155724;
    }
</style>

<div class="login-container">
    <div class="login-form">
        <h3>🔐 LOGOWANIE</h3>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">
                @ViewBag.Error
            </div>
        }

        @if (ViewBag.recovered == "true" || Context.Request.Query["recovered"] == "true")
        {
            <div class="alert alert-success">
                Hasło zostało zresetowane! Sprawdź swój e-mail, aby uzyskać nowe hasło tymczasowe.
            </div>
        }

        <form method="post">
            <div class="form-group">
                <input type="text" name="login" placeholder="Login" class="form-control" required />
            </div>
            <div class="form-group">
                <input type="password" name="password" placeholder="Hasło" class="form-control" required />
            </div>

            <div class="btn-group">
                <button type="submit" class="btn-login">Zaloguj się</button>
                <a asp-controller="Account" asp-action="Rejestracja" class="btn-register">Rejestracja</a>
            </div>
        </form>

        <a asp-controller="Account" asp-action="OdzyskajHaslo" class="btn-recovery">
            ❓ Odzyskaj hasło
        </a>
    </div>
</div>
