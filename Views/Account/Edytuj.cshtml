@model przychodnia.Models.Uzytkownik

<div class="container mt-4">
    <div class="card shadow-sm" style="max-width: 600px; margin: auto; border-radius: 10px;">
        <div class="card-header text-white" style="background-color: #1B263B;">
            <h4 class="mb-0">Edycja profilu: @Model.Imie @Model.Nazwisko</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edytuj" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ID" />

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Imię</label>
                    <input asp-for="Imie" class="form-control" />
                    <span asp-validation-for="Imie" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Nazwisko</label>
                    <input asp-for="Nazwisko" class="form-control" />
                    <span asp-validation-for="Nazwisko" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Adres E-mail</label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Numer PESEL</label>
                    <input asp-for="Pesel" class="form-control" />
                    <span asp-validation-for="Pesel" class="text-danger small"></span>
                </div>

                <hr />

                <div class="d-flex justify-content-between align-items-center mt-4">
                    <a href="@Url.Action("Podglad", new { id = Model.ID })" class="btn btn-outline-secondary">
                        Anuluj
                    </a>
                    <button type="submit" class="btn btn-primary px-4" style="background-color: #1B263B; border: none;">
                        Zapisz zmiany
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @* Skrypty do walidacji po stronie przeglądarki (bez przeładowania strony) *@
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
