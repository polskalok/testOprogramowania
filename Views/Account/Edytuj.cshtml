@model przychodnia.Models.Uzytkownik

<div class="container mt-4">
    <div class="card shadow-sm" style="max-width: 600px; margin: auto; border-radius: 10px;">
        
        @if (!Model.CzyAktywny)
        {
            @* zapomniany *@
            <div class="card-header text-white" style="background-color: #721c24;">
                <h4 class="mb-0">Błąd: Edycja zablokowana</h4>
            </div>
            <div class="card-body p-4 text-center">
                <div class="alert alert-warning mb-4">
                    <i class="fas fa-user-lock fa-2x mb-3"></i>
                    <p style="font-size: 1.1rem;"><strong>Nie można edytować danych użytkownika zapomnianego.</strong></p>
                    <p class="text-muted small">Konto to zostało zanonimizowane i wyłączone z edycji.</p>
                </div>
                <a href="@Url.Action("AdminPanel", "Account")" class="btn btn-secondary">
                    Wróć do listy użytkowników
                </a>
            </div>
        }
        else
        {
            @* zwykly *@
            <div class="card-header text-white" style="background-color: #1B263B;">
                <h4 class="mb-0">Edycja profilu: @Model.Imie @Model.Nazwisko</h4>
            </div>
            <div class="card-body p-4">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <h5>Błędy walidacji:</h5>
                        <ul class="mb-0">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        </ul>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form asp-action="Edytuj" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ID" />

                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Imię</label>
                        <input asp-for="Imie" class="form-control" />
                        <span asp-validation-for="Imie" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Nazwisko</label>
                        <input asp-for="Nazwisko" class="form-control" />
                        <span asp-validation-for="Nazwisko" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Adres E-mail</label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Numer PESEL</label>
                        <input asp-for="Pesel" class="form-control" />
                        <span asp-validation-for="Pesel" class="text-danger small"></span>
                    </div>

                    <hr />

                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <a href="@Url.Action("Podglad", new { id = Model.ID })" class="btn btn-outline-secondary">
                            Anuluj
                        </a>
                        <button type="submit" class="btn btn-primary px-4" style="background-color: #1B263B; border: none;">
                            Zapisz zmiany
                        </button>
                    </div>
                </form>
            </div>
        }
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}