@model przychodnia.Models.Uzytkownik

@{
    ViewData["Title"] = "Dodaj Nowego Użytkownika";
}

<div style="max-width: 600px; margin: auto; background: white; padding: 25px; border-radius: 10px; border: 1px solid #dee2e6;">
    <h2 style="border-bottom: 3px solid #1B263B; padding-bottom: 10px;">Nowy Użytkownik</h2>

    <form asp-action="DodajUzytkownik" method="post">
        <div class="row">
            <div class="col-md-6 mb-3">
                <label>Login</label>
                <input asp-for="Login" class="form-control" required />
            </div>
            <div class="col-md-6 mb-3">
                <label>Hasło</label>
                <input asp-for="Haslo" type="password" class="form-control" required />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label>Imię</label>
                <input asp-for="Imie" class="form-control" required />
            </div>
            <div class="col-md-6 mb-3">
                <label>Nazwisko</label>
                <input asp-for="Nazwisko" class="form-control" required />
            </div>
        </div>

        <div class="mb-3">
            <label>Adres</label>
            <input asp-for="Adres" class="form-control" />
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label>PESEL</label>
                <input asp-for="Pesel" class="form-control" maxlength="11" required />
            </div>
            <div class="col-md-6 mb-3">
                <label>Płeć</label>
                <select asp-for="Plec" class="form-control">
                    <option value="Mężczyzna">Mężczyzna</option>
                    <option value="Kobieta">Kobieta</option>
                </select>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label>Email</label>
                <input asp-for="Email" type="email" class="form-control" />
            </div>
            <div class="col-md-6 mb-3">
                <label>Telefon</label>
                <input asp-for="Telefon" class="form-control" />
            </div>
        </div>

        <div class="mb-3">
            <label>Uprawnienia</label>
            <select asp-for="Permisje" class="form-control">
                <option value="0">Użytkownik (Pacjent)</option>
                <option value="1">Administrator</option>
                <option value="2">Pracownik</option>
            </select>
        </div>

        <hr />
        <div class="text-end">
            <a href="@Url.Action("AdminPanel")" class="btn btn-outline-secondary">Anuluj</a>
            <button type="submit" class="btn btn-primary" style="background-color: #1B263B;">Zapisz Użytkownika</button>
        </div>
    </form>
</div>