@{
    ViewData["Title"] = "Logowanie";
}

<div style="max-width: 400px; margin: auto; text-align: center;">
    <h3>LOGOWANIE</h3>
    <hr />
    <form method="post">
        <input type="text" name="login" placeholder="Login" class="form-control mb-2" required />
        <input type="password" name="password" placeholder="Hasło" class="form-control mb-2" required />
        
        <button type="submit" class="btn btn-primary w-100">Zaloguj się</button>
        <button type="button" class="btn btn-secondary w-100 mt-2">Rejestracja</button>
    </form>
    
    @if(ViewBag.Error != null) {
        <p class="text-danger mt-2">@ViewBag.Error</p>
    }
</div>