using System.Security.Cryptography;
using System.Text;
using System.Text.RegularExpressions;

namespace przychodnia.Services 
{
    public static class PasswordHasher
    {
        private static readonly string SpecialCharsPattern = @"[-_!*$#&]";

        public static string HashPassword(string password)
        {
            if (string.IsNullOrEmpty(password)) return string.Empty;

            using (SHA256 sha256Hash = SHA256.Create())
            {
                // Zamiana hasła na tablicę bajtów
                byte[] bytes = sha256Hash.ComputeHash(Encoding.UTF8.GetBytes(password));

                // Konwersja bajtów na tekst w formacie szesnastkowym (hex)
                StringBuilder builder = new StringBuilder();
                for (int i = 0; i < bytes.Length; i++)
                {
                    builder.Append(bytes[i].ToString("x2"));
                }
                return builder.ToString();
            }
        }

        public static bool ValidatePassword(string password, out string errorMessage)
        {
            errorMessage = string.Empty;

            if (string.IsNullOrEmpty(password))
            {
                errorMessage = "Hasło jest wymagane";
                return false;
            }

            if (password.Length < 8 || password.Length > 15)
            {
                errorMessage = "Neprawidłowe hasło. Upewnij się, że: ma od 8 do 15 znaków zawiera wielką i małą literę zawiera przynajmniej jedną cyfrę zawiera znak specjalny (- _ ! * $ # &)";
                return false;
            }

            if (!password.Any(char.IsUpper))
            {
                errorMessage = "Neprawidłowe hasło. Upewnij się, że: ma od 8 do 15 znaków zawiera wielką i małą literę zawiera przynajmniej jedną cyfrę zawiera znak specjalny (- _ ! * $ # &)";
                return false;
            }

            if (!password.Any(char.IsLower))
            {
                errorMessage = "Neprawidłowe hasło. Upewnij się, że: ma od 8 do 15 znaków zawiera wielką i małą literę zawiera przynajmniej jedną cyfrę zawiera znak specjalny (- _ ! * $ # &)";
                return false;
            }

            if (!password.Any(char.IsDigit))
            {
                errorMessage = "Neprawidłowe hasło. Upewnij się, że: ma od 8 do 15 znaków zawiera wielką i małą literę zawiera przynajmniej jedną cyfrę zawiera znak specjalny (- _ ! * $ # &)";
                return false;
            }

            if (!Regex.IsMatch(password, SpecialCharsPattern))
            {
                errorMessage = "Neprawidłowe hasło. Upewnij się, że: ma od 8 do 15 znaków zawiera wielką i małą literę zawiera przynajmniej jedną cyfrę zawiera znak specjalny (- _ ! * $ # &)";
                return false;
            }

            return true;
        }
    }
}